# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_API_TIMEOUT=30000

# Mapbox and Maps
NEXT_PUBLIC_MAPBOX_TOKEN=pk_test_your_mapbox_token_here
NEXT_PUBLIC_MAP_STYLE=mapbox://styles/mapbox/streets-v12
NEXT_PUBLIC_INITIAL_LATITUDE=-1.9505
NEXT_PUBLIC_INITIAL_LONGITUDE=29.8739
NEXT_PUBLIC_INITIAL_ZOOM=10

# Google Maps (Alternative)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Authentication
NEXT_PUBLIC_AUTH_PROVIDER=next-auth
NEXTAUTH_SECRET=your_nextauth_secret_key_here
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_JWT_EXPIRY=86400

# Payment Integration
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Mobile Money Providers
NEXT_PUBLIC_MTN_API_URL=https://api.mtn.co.rw/v1
NEXT_PUBLIC_AIRTEL_API_URL=https://api.airtel.co.rw/v1

# Application Settings
NEXT_PUBLIC_APP_NAME=Land Valuation System
NEXT_PUBLIC_APP_DESCRIPTION=Accurate land pricing and marketplace for Rwanda
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_DEBUG=true

# Logging and Analytics
NEXT_PUBLIC_ANALYTICS_ID=your_google_analytics_id
NEXT_PUBLIC_SENTRY_DSN=

# Cache Strategy
NEXT_PUBLIC_CACHE_TTL=3600
NEXT_PUBLIC_ISR_REVALIDATE=60

# Feature Flags
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_SUBSCRIPTION=true
NEXT_PUBLIC_ENABLE_ADVANCED_ANALYTICS=false
NEXT_PUBLIC_ENABLE_MOBILE_INTEGRATION=true

# Email Configuration
NEXT_PUBLIC_SUPPORT_EMAIL=support@landvaluation.rw
NEXT_PUBLIC_CONTACT_EMAIL=contact@landvaluation.rw

# Rate Limiting
NEXT_PUBLIC_REQUEST_RATE_LIMIT=100
NEXT_PUBLIC_RATE_LIMIT_WINDOW=900000

# Localization
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_SUPPORTED_LANGUAGES=en,rw,fr

# External APIs for Marketplace Tracking
NEXT_PUBLIC_MARKETPLACE_API_KEYS={"api1":"key1","api2":"key2"}
