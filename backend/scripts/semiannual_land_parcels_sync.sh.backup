
# ...existing code...
# Semiannual incremental land parcel sync.
# Expected input CSV columns:
# upi,district,sector,cell,village,land_size_sqm,base_price_per_sqm,zone_coefficient,property_type,zoning_type

# Always set SCRIPT_DIR and BACKEND_DIR at the top, robustly
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
BACKEND_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

if [[ -f "$BACKEND_DIR/.env" ]]; then
  while IFS='=' read -r key value; do
    case "$key" in
      DB_HOST|DB_PORT|DB_USER|DB_NAME|DB_PASSWORD)
        export "$key=${value}"
        ;;
    esac
  done < <(grep -E '^(DB_HOST|DB_PORT|DB_USER|DB_NAME|DB_PASSWORD)=' "$BACKEND_DIR/.env")
fi

: "${DB_HOST:=localhost}"
: "${DB_PORT:=5432}"
: "${DB_USER:?DB_USER is required}"
: "${DB_NAME:?DB_NAME is required}"
: "${DB_PASSWORD:?DB_PASSWORD is required}"

CSV_FILE="${1:-}"
RANDOM_BATCH=$(( 180000 + RANDOM % 40000 ))
BATCH_SIZE="${BATCH_SIZE:-$RANDOM_BATCH}"
SOURCE_NAME="${SOURCE_NAME:-ubutaka}"


if [[ -z "$CSV_FILE" ]]; then
  echo "Usage: $0 <semiannual_batch.csv>"
  exit 1
fi

if [[ ! -f "$CSV_FILE" ]]; then
  echo "CSV file not found: $CSV_FILE"
  exit 1
fi

if ! [[ "$BATCH_SIZE" =~ ^[0-9]+$ ]]; then
  echo "BATCH_SIZE must be numeric"
  exit 1
fi


PGURL="postgresql://${DB_USER}@${DB_HOST}:${DB_PORT}/${DB_NAME}"
TMP_CSV="/tmp/land_sync_batch_$$.csv"
TMP_CSV_NORMALIZED="/tmp/land_sync_batch_normalized_$$.csv"
TMP_SQL="/tmp/land_sync_run_$$.sql"
trap 'rm -f "$TMP_CSV" "$TMP_CSV_NORMALIZED" "$TMP_SQL"' EXIT

# Keep only first BATCH_SIZE rows (+ header) so semiannual runs stay bounded.
awk -v limit="$BATCH_SIZE" 'NR==1 || (NR>1 && NR<=limit+1)' "$CSV_FILE" > "$TMP_CSV"

# Now generate the SQL file, after TMP_CSV exists
cat > "$TMP_SQL" <<SQL
BEGIN;


CREATE TEMP TABLE ubutaka_stage (
  upi bigint,
  d text,
  p text,
  s integer,
  b integer,
  z double precision,
  t text,
  x text
);

\copy ubutaka_stage(upi,d,p,s,b,z,t,x) FROM '$TMP_CSV' WITH (FORMAT csv, HEADER true)

INSERT INTO ubutaka (
  upi, d, p, s, b, z, t, x
)
SELECT
  s.upi,
  s.d,
  s.p,
  s.s,
  s.b,
  s.z,
  s.t,
  s.x
FROM ubutaka_stage s
WHERE s.upi IS NOT NULL
ON CONFLICT (upi) DO UPDATE SET
  d = EXCLUDED.d,
  p = EXCLUDED.p,
  s = EXCLUDED.s,
  b = EXCLUDED.b,
  z = EXCLUDED.z,
  t = EXCLUDED.t,
  x = EXCLUDED.x;

COMMIT;

SELECT COUNT(*) AS total_ubutaka FROM ubutaka;
SQL





# --- Automated Reporting ---

REPORT_FILE="$BACKEND_DIR/logs/land_sync_report_$(date +%Y%m%d_%H%M%S).txt"
echo "[INFO] Ubutaka sync started." | tee -a "$REPORT_FILE"
echo "[INFO] Batch size: $BATCH_SIZE | Source: $SOURCE_NAME" | tee -a "$REPORT_FILE"
if [[ -n "${http_proxy:-}" ]]; then
  echo "[INFO] Using proxy: ${http_proxy}" | tee -a "$REPORT_FILE"
fi

# Get row count before sync
COUNT_BEFORE=$(PGPASSWORD="$DB_PASSWORD" psql -U "$DB_USER" -h "$DB_HOST" -d "$DB_NAME" -t -c "SELECT COUNT(*) FROM ubutaka;" | xargs)
echo "[REPORT] Row count before sync: $COUNT_BEFORE" | tee -a "$REPORT_FILE"


# DB import, capture errors
if env PGPASSWORD="$DB_PASSWORD" psql "$PGURL" -v ON_ERROR_STOP=1 -f "$TMP_SQL" 2>>"$REPORT_FILE"; then
  echo "[INFO] Ubutaka sync completed successfully." | tee -a "$REPORT_FILE"
else
  echo "[ERROR] Ubutaka sync failed. See above for details." | tee -a "$REPORT_FILE"
  exit 1
fi

# Get row count after sync
COUNT_AFTER=$(PGPASSWORD="$DB_PASSWORD" psql -U "$DB_USER" -h "$DB_HOST" -d "$DB_NAME" -t -c "SELECT COUNT(*) FROM ubutaka;" | xargs)
echo "[REPORT] Row count after sync: $COUNT_AFTER" | tee -a "$REPORT_FILE"


# Summary
echo "[SUMMARY] Records added or updated: $((COUNT_AFTER-COUNT_BEFORE))" | tee -a "$REPORT_FILE"
echo "[SUMMARY] Report written to $REPORT_FILE"

# --- Email Notification ---
EMAIL_TO="jeanrenemunyeshyaka@gmail.com,munyeshyaka@hotmail.com"

# Use .env EMAIL_USER and EMAIL_PASS for SMTP authentication
EMAIL_FROM="noreply@landval.kcoders.org"
EMAIL_SUBJECT="[Land Valuation System] Land Sync Report $(date +%Y-%m-%d' '%H:%M:%S)"
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="${EMAIL_USER:-jeanrenemunyeshyaka@gmail.com}"
SMTP_PASS="${EMAIL_PASS:-ermdnasdxlcddnrc}"

if command -v python3 >/dev/null 2>&1; then
export SMTP_USER EMAIL_PASS
python3 - <<EOF
import smtplib
from email.mime.multipart import MIMEMultipart
from email.mime.text import MIMEText
from email.mime.base import MIMEBase
from email import encoders
import os

smtp_server = os.environ.get('SMTP_SERVER', '$SMTP_SERVER')
smtp_port = int(os.environ.get('SMTP_PORT', $SMTP_PORT))
smtp_user = os.environ.get('SMTP_USER', '$SMTP_USER')
smtp_pass = os.environ.get('EMAIL_PASS', '$SMTP_PASS')
email_from = '$EMAIL_FROM'
email_to = '$EMAIL_TO'
recipients = [addr.strip() for addr in email_to.split(',') if addr.strip()]
subject = "$EMAIL_SUBJECT"
report_file = "$REPORT_FILE"

msg = MIMEMultipart()
msg['From'] = email_from
msg['To'] = email_to
msg['Subject'] = subject

with open(report_file, 'r') as f:
  report_content = f.read()
msg.attach(MIMEText(report_content, 'plain'))

part = MIMEBase('application', 'octet-stream')
part.set_payload(report_content)
encoders.encode_base64(part)
part.add_header('Content-Disposition', f'attachment; filename="{os.path.basename(report_file)}"')
msg.attach(part)

try:
  server = smtplib.SMTP(smtp_server, smtp_port)
  server.starttls()
  server.login(smtp_user, smtp_pass)
  server.sendmail(email_from, recipients, msg.as_string())
  server.quit()
  print(f"[INFO] Report emailed to {email_to}")
except Exception as e:
  print(f"[ERROR] Failed to send email: {e}")
EOF
else
  echo "[WARN] Python3 not found, skipping email notification."
fi
