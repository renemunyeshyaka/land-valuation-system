# Backend Environment Variables
ENVIRONMENT=development
PORT=8080
HOST=0.0.0.0

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=land_valuation
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=10

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=land_valuation

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=86400
JWT_REFRESH_EXPIRY=2592000

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_MAX_AGE=86400
CORS_ALLOW_CREDENTIALS=true

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_PASS=your-app-password
SMTP_FROM=noreply@landvaluation.rw
SUPPORT_EMAIL=support@landvaluation.rw

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=10
LOG_MAX_AGE=30

# Payment Integration
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_test_webhook_secret

# Mobile Money Integration
MTN_API_URL=https://api.mtn.co.rw/v1
MTN_API_KEY=your_mtn_api_key
MTN_API_SECRET=your_mtn_api_secret
MTN_WEBHOOK_SECRET=your_mtn_webhook_secret

AIRTEL_API_URL=https://api.airtel.co.rw/v1
AIRTEL_API_KEY=your_airtel_api_key
AIRTEL_API_SECRET=your_airtel_api_secret
AIRTEL_WEBHOOK_SECRET=your_airtel_webhook_secret

# Mapbox Integration
MAPBOX_API_TOKEN=pk_test_your_mapbox_token
MAPBOX_API_URL=https://api.mapbox.com

# External Marketplace APIs
MARKETPLACE_API_KEYS={"api1":"key1","api2":"key2"}
MARKETPLACE_SYNC_INTERVAL=3600
MARKETPLACE_TIMEOUT=30

# Rwanda Land Authority API
RWANDA_LAND_AUTHORITY_URL=https://api.rha.gov.rw
RWANDA_LAND_AUTHORITY_API_KEY=your_rha_api_key

# Rwanda GIS Data
RWANDA_GIS_API_URL=https://gis.naturalearth.data
RWANDA_GIS_API_KEY=your_gis_api_key

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_BATCH_SIZE=100
ANALYTICS_FLUSH_INTERVAL=60

# Security Configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900
RATE_LIMIT_ENABLED=true

# 2FA Configuration
TWO_FA_ISSUER=Land Valuation System
TWO_FA_WINDOW=1

# Password Configuration
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# Geocoding Service
GEOCODING_SERVICE=mapbox
GEOCODING_CACHE_TTL=86400

# Admin Settings
# ADMIN_EMAIL=admin@landvaluation.rw  # removed as requested
ENABLE_TEST_ENDPOINTS=false
ENABLE_DEBUG_LOGGING=true

# Feature Flags
FEATURE_MARKETPLACE_TRACKING=true
FEATURE_ADVANCED_ANALYTICS=false
FEATURE_API_AGGREGATION=true

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000
CACHE_ENABLED=true

# API Rate Limiting
API_RATE_LIMIT=1000
API_RATE_LIMIT_BURST=100

# Versioning
API_VERSION=v1
BUILD_VERSION=1.0.0
BUILD_TIME=2026-02-25T00:00:00Z


#Mapbox Configuration
MAPBOX_TOKEN=your-mapbox-api-token