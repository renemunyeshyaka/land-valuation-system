{
  "name": "land-valuation-mobile",
  "version": "1.0.0",
  "description": "Land Valuation System - React Native Mobile App",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "web": "expo start --web",
    "start": "react-native start",
    "build:android": "cd android && ./gradlew assembleRelease && cd ..",
    "build:ios": "cd ios && xcodebuild -workspace LandValuation.xcworkspace -scheme LandValuation -configuration Release -derivedDataPath build && cd ..",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
    "clean": "rm -rf node_modules && npm install",
    "clean:android": "cd android && ./gradlew clean && cd ..",
    "clean:ios": "cd ios && rm -rf build && rm -rf Pods && pod install && cd ..",
    "prebuild": "expo prebuild --clean",
    "eas:build:android": "eas build --platform android --auto-submit",
    "eas:build:ios": "eas build --platform ios --auto-submit",
    "eas:submit": "eas submit"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@react-navigation/stack": "^6.3.20",
    "@reduxjs/toolkit": "^1.9.7",
    "@stripe/stripe-react-native": "^0.30.0",
    "axios": "^1.6.2",
    "date-fns": "^2.30.0",
    "expo": "^50.0.0",
    "expo-auth-session": "^5.4.0",
    "expo-av": "^13.10.9",
    "expo-camera": "^14.1.1",
    "expo-contacts": "^11.3.0",
    "expo-file-system": "^15.4.4",
    "expo-font": "^12.0.0",
    "expo-geolocation": "^14.6.0",
    "expo-haptics": "^12.8.1",
    "expo-image-picker": "^14.7.1",
    "expo-intent-launcher": "^12.2.0",
    "expo-linking": "^6.0.0",
    "expo-location": "^16.5.4",
    "expo-notifications": "^0.27.0",
    "expo-splash-screen": "^0.26.5",
    "expo-status-bar": "^1.7.1",
    "expo-web-browser": "^12.8.2",
    "formik": "^2.4.5",
    "js-sha256": "^0.9.0",
    "lodash": "^4.17.21",
    "mapbox-gl": "^3.0.1",
    "react": "^18.2.0",
    "react-native": "0.73.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-get-random-values": "^1.10.0",
    "react-native-maps": "^1.10.0",
    "react-native-reanimated": "^3.6.0",
    "react-native-safe-area-context": "^4.8.1",
    "react-native-screens": "^3.28.0",
    "react-native-svg": "^14.0.0",
    "react-native-web": "^0.19.10",
    "react-redux": "^8.1.3",
    "redux": "^4.2.1",
    "yup": "^1.3.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@react-native/babel-preset": "0.73.0",
    "@react-native/metro-config": "0.73.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.3.0",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.4",
    "@types/react": "^18.2.45",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "babel-jest": "^29.7.0",
    "eas-cli": "^7.1.1",
    "eslint": "^8.55.0",
    "eslint-config-react-app": "^7.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "metro": "^0.80.5",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.1.0",
    "react-test-renderer": "^18.2.0",
    "typescript": "^5.3.2"
  },
  "private": true,
  "author": "Land Valuation Team",
  "license": "Proprietary"
}
